# DreamHost Passenger + Django .htaccess

PassengerEnabled On
PassengerAppRoot /home/cms_admin1/cms.reachapac.org
PassengerVirtualEnvRoot /home/cms_admin1/cms.reachapac.org/venv
PassengerPython /home/cms_admin1/cms.reachapac.org/venv/bin/python
PassengerStartupFile passenger_wsgi.py

# Static files
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^static/(.*)$ /home/cms_admin1/cms.reachapac.org/staticfiles/$1 [L]
    RewriteRule ^media/(.*)$ /home/cms_admin1/cms.reachapac.org/media/$1 [L]
</IfModule>

# Security headers
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
</IfModule>

# Protect sensitive files
<FilesMatch "\.(env|sqlite|py|md)$">
    Order allow,deny
    Deny from all
</FilesMatch>
